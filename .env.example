# Django settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL database (local / Docker)
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL container settings (used by docker-compose)
POSTGRES_DB=portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full database URL (used by Railway, FastAPI, and dj-database-url)
DATABASE_URL=postgresql://postgres@localhost:5432/portfolio

# FastAPI CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# FastAPI service URL (used by Django to point contact form)
FASTAPI_URL=http://localhost:8001
